<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Minecraft Mobile: Capas y Colinas</title>
    <style>
        body { 
            margin: 0; padding: 0; overflow: hidden; touch-action: none; 
            background: #87CEEB; position: fixed; width: 100%; height: 100%; font-family: sans-serif;
        }
        canvas { display: block; width: 100%; height: 100%; }
        #controles {
            position: absolute; bottom: 30px; left: 30px;
            display: grid; grid-template-columns: repeat(3, 60px); grid-template-rows: repeat(2, 60px); gap: 10px; z-index: 10;
        }
        .btn {
            width: 60px; height: 60px; background: rgba(0,0,0,0.5);
            border: 2px solid #fff; border-radius: 15px;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 28px; user-select: none; -webkit-user-select: none;
        }
        #btn-up { grid-column: 2; }
        #btn-left { grid-column: 1; grid-row: 2; }
        #btn-down { grid-column: 2; grid-row: 2; }
        #btn-right { grid-column: 3; grid-row: 2; }
    </style>
</head>
<body>

    <div id="controles">
        <div class="btn" id="btn-up">↑</div>
        <div class="btn" id="btn-left">←</div>
        <div class="btn" id="btn-down">↓</div>
        <div class="btn" id="btn-right">→</div>
    </div>

    <script type="module">
        import * as THREE from 'https://cdn.skypack.dev/three@0.132.2';

        // --- 1. ESCENA ---
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x87CEEB);
        scene.fog = new THREE.Fog(0x87CEEB, 10, 40);

        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ antialias: false });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.body.appendChild(renderer.domElement);

        const light = new THREE.DirectionalLight(0xffffff, 1.2);
        light.position.set(10, 20, 10);
        scene.add(light);
        scene.add(new THREE.AmbientLight(0xffffff, 0.6));

        // --- 2. TEXTURAS ---
        function createPixelTexture(r, g, b, noiseRange = 25, size = 16, detail = false) {
            const canvas = document.createElement('canvas');
            canvas.width = size; canvas.height = size;
            const ctx = canvas.getContext('2d');
            for(let x=0; x<size; x++) {
                for(let y=0; y<size; y++) {
                    let n = Math.random() * noiseRange;
                    let pr = r - n, pg = g - n, pb = b - n;
                    if (detail && Math.random() > 0.85) { pr = r + 30; pg = g + 40; pb = b; }
                    ctx.fillStyle = `rgb(${pr}, ${pg}, ${pb})`;
                    ctx.fillRect(x, y, 1, 1);
                }
            }
            const tex = new THREE.CanvasTexture(canvas);
            tex.magFilter = THREE.NearestFilter;
            tex.minFilter = THREE.NearestFilter;
            return tex;
        }

        const grassTex = createPixelTexture(90, 170, 60, 30, 32, true); 
        const dirtTex = createPixelTexture(120, 85, 50);
        const woodTex = createPixelTexture(95, 65, 40);
        const leafTex = createPixelTexture(50, 120, 40, 20, 16, true);
        const pigTex = createPixelTexture(255, 180, 190, 15);

        // --- 3. MATERIALES ---
        const dirtMat = new THREE.MeshLambertMaterial({map: dirtTex}); // Material solo de tierra
        const grassMatSides = new THREE.MeshLambertMaterial({map: dirtTex});
        const grassMatTop = new THREE.MeshLambertMaterial({map: grassTex});
        const grassMaterials = [grassMatSides, grassMatSides, grassMatTop, grassMatSides, grassMatSides, grassMatSides];
        
        const woodMat = new THREE.MeshLambertMaterial({map: woodTex});
        const leafMat = new THREE.MeshLambertMaterial({map: leafTex});
        const pigMat = new THREE.MeshLambertMaterial({map: pigTex});

        // --- 4. FUNCIÓN PARA ALTURA DEL TERRENO ---
        function getTerrainHeight(x, z) {
            // Crea colinas onduladas matemáticas
            return Math.floor(Math.sin(x / 6) * 1.5 + Math.cos(z / 6) * 1.5);
        }

        // --- 5. MUNDO CON CAPAS ---
        const boxGeo = new THREE.BoxGeometry(1, 1, 1);
        for (let x = -30; x < 30; x++) {
            for (let z = -30; z < 30; z++) {
                const surfaceY = getTerrainHeight(x, z);

                // Generar 3 capas de profundidad
                for (let y = surfaceY - 2; y <= surfaceY; y++) {
                    const isTopLayer = (y === surfaceY);
                    // Si es la capa más alta usa césped, si no, usa solo tierra
                    const block = new THREE.Mesh(boxGeo, isTopLayer ? grassMaterials : dirtMat);
                    block.position.set(x, y, z);
                    scene.add(block);
                }

                // Generar árboles en la superficie
                if (Math.random() > 0.985) { 
                    const trunkHeight = 4 + Math.floor(Math.random() * 3);
                    for(let i=1; i<=trunkHeight; i++) {
                        const trunk = new THREE.Mesh(boxGeo, woodMat);
                        trunk.position.set(x, surfaceY + i, z);
                        scene.add(trunk);
                    }
                    for(let y = trunkHeight - 2; y <= trunkHeight + 1; y++) {
                        let radius = (y === trunkHeight + 1) ? 1 : 2;
                        for(let lx = -radius; lx <= radius; lx++) {
                            for(let lz = -radius; lz <= radius; lz++) {
                                if (Math.abs(lx) === radius && Math.abs(lz) === radius && (y === trunkHeight + 1 || y === trunkHeight - 2 || Math.random() > 0.5)) continue;
                                if (lx === 0 && lz === 0 && y <= trunkHeight) continue;
                                const leaf = new THREE.Mesh(boxGeo, leafMat);
                                leaf.position.set(x+lx, surfaceY + y, z+lz);
                                scene.add(leaf);
                            }
                        }
                    }
                }
            }
        }

        // --- 6. ANIMAL ---
        function createPig() {
            const group = new THREE.Group();
            const body = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.7, 1.2), pigMat);
            body.position.y = 0.65;
            const head = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.6, 0.6), pigMat);
            head.position.set(0, 1.0, 0.7);
            const eye = new THREE.Mesh(new THREE.BoxGeometry(0.1, 0.1, 0.1), new THREE.MeshBasicMaterial({color: 0x000000}));
            const eyeL = eye.clone(); eyeL.position.set(0.2, 1.15, 1.0);
            const eyeR = eye.clone(); eyeR.position.set(-0.2, 1.15, 1.0);
            const snout = new THREE.Mesh(new THREE.BoxGeometry(0.3, 0.2, 0.1), new THREE.MeshLambertMaterial({color: 0xffa0b0}));
            snout.position.set(0, 0.95, 1.0);
            group.add(body, head, eyeL, eyeR, snout);
            for(let i=0; i<4; i++) {
                const leg = new THREE.Mesh(new THREE.BoxGeometry(0.25, 0.4, 0.25), pigMat);
                leg.position.set(i<2?0.25:-0.25, 0.2, i%2?0.35:-0.35);
                group.add(leg);
            }
            return group;
        }
        const pig = createPig();
        scene.add(pig);
        pig.position.set(4, 0, 4);

        // --- 7. CONTROLES ---
        camera.position.set(0, 5, 8);
        let move = { f: false, b: false, l: false, r: false };
        let yaw = 0, pitch = 0, lastX = 0, lastY = 0;

        const setupBtn = (id, dir) => {
            const btn = document.getElementById(id);
            btn.addEventListener('touchstart', (e) => { e.preventDefault(); move[dir] = true; });
            btn.addEventListener('touchend', (e) => { e.preventDefault(); move[dir] = false; });
        };
        setupBtn('btn-up', 'f'); setupBtn('btn-down', 'b'); setupBtn('btn-left', 'l'); setupBtn('btn-right', 'r');

        document.addEventListener('touchstart', e => {
            if(e.touches[0].target.tagName === 'CANVAS') {
                lastX = e.touches[0].pageX; lastY = e.touches[0].pageY;
            }
        }, {passive: false});

        document.addEventListener('touchmove', e => {
            if(e.touches[0].target.tagName === 'CANVAS') {
                const sensitivity = 0.006;
                yaw -= (e.touches[0].pageX - lastX) * sensitivity;
                pitch -= (e.touches[0].pageY - lastY) * sensitivity;
                pitch = Math.max(-1.4, Math.min(1.4, pitch));
                lastX = e.touches[0].pageX; lastY = e.touches[0].pageY;
            }
        }, {passive: false});

        // --- 8. AJUSTE DE PANTALLA ---
        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }
        window.addEventListener('resize', onWindowResize);
        window.addEventListener('orientationchange', () => setTimeout(onWindowResize, 200));

        // --- 9. ANIMACIÓN Y FÍSICAS ---
        function animate() {
            requestAnimationFrame(animate);
            camera.rotation.order = "YXZ";
            camera.rotation.y = yaw;
            camera.rotation.x = pitch;

            const speed = 0.15;
            if (move.f) camera.translateZ(-speed);
            if (move.b) camera.translateZ(speed);
            if (move.l) camera.translateX(-speed);
            if (move.r) camera.translateX(speed);

            // Gravedad dinámica para el jugador (caminar por colinas)
            const playerGridX = Math.round(camera.position.x);
            const playerGridZ = Math.round(camera.position.z);
            const targetCamY = getTerrainHeight(playerGridX, playerGridZ) + 1.8;
            // Interpolar (suavizar) la subida/bajada de la cámara
            camera.position.y += (targetCamY - camera.position.y) * 0.15;

            // Gravedad dinámica para el cerdito
            pig.position.z += 0.03;
            if (pig.position.z > 25) pig.position.z = -25;
            pig.rotation.y += 0.005;
            
            const pigGridX = Math.round(pig.position.x);
            const pigGridZ = Math.round(pig.position.z);
            const targetPigY = getTerrainHeight(pigGridX, pigGridZ);
            pig.position.y += (targetPigY - pig.position.y) * 0.2;

            renderer.render(scene, camera);
        }
        animate();
    </script>
</body>
</html>
